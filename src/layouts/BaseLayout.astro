---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Fünfgroschenverlag — ein Verlag, viele Welten',
  description = 'Zwölf Pen-Names, ein Verlag. Geschichten, die Spiegel sind. MM Romance, Polit-Fantasy, Crime, Coming-of-Age, Self-Help — alles unter einem Dach.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://hub.app.fuenfgroschenverlag.com');
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.toString()} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:image" content="https://images.app.fuenfgroschenverlag.com/pen-vitrinen/fgv-logo.png" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://images.app.fuenfgroschenverlag.com/pen-vitrinen/fgv-logo.png" />

    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#14100a" />
  </head>
  <body>
    <slot />
  </body>
</html>
